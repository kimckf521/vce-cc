generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Topic {
  id          String     @id @default(cuid())
  name        String     @unique
  createdAt   DateTime   @default(now())
  description String?
  order       Int        @default(0)
  slug        String     @unique
  questions   Question[]
  subtopics   Subtopic[]
  questionSetItems QuestionSetItem[]
}

model Subtopic {
  id        String     @id @default(cuid())
  name      String
  slug      String
  order     Int        @default(0)
  topicId   String
  topic     Topic      @relation(fields: [topicId], references: [id], onDelete: Cascade)
  questions Question[] @relation("QuestionToSubtopic")
  questionSetItems QuestionSetItem[] @relation("QuestionSetItemToSubtopic")

  @@unique([topicId, slug])
}

model Exam {
  id        String     @id @default(cuid())
  year      Int
  examType  ExamType
  createdAt DateTime   @default(now())
  answerUrl String?
  pdfUrl    String?
  questions Question[]

  @@unique([year, examType])
}

model Question {
  id             String     @id @default(cuid())
  examId         String
  marks          Int
  createdAt      DateTime   @default(now())
  content        String
  difficulty     Difficulty @default(MEDIUM)
  imageUrl       String?
  part           String?
  questionNumber Int
  topicId        String
  updatedAt      DateTime   @updatedAt
  attempts       Attempt[]
  exam           Exam       @relation(fields: [examId], references: [id], onDelete: Cascade)
  topic          Topic      @relation(fields: [topicId], references: [id])
  solution       Solution?
  subtopics      Subtopic[] @relation("QuestionToSubtopic")

  @@index([topicId, difficulty])
  @@index([examId, questionNumber])
  @@index([topicId, examId])
}

model Solution {
  id         String   @id @default(cuid())
  questionId String   @unique
  content    String
  imageUrl   String?
  videoUrl   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model User {
  id                   String               @id
  email                String               @unique
  name                 String?
  createdAt            DateTime             @default(now())
  role                 Role                 @default(STUDENT)
  stripeCustomerId     String?              @unique
  referredByCode       String?              // Referral code used at signup (immutable record)
  activeSessionId      String?              // Single-active-session enforcement — new logins rotate this, stale sessions get kicked
  attempts             Attempt[]
  examSessions         ExamSession[]
  extractionSessions   ExtractionSession[]
  enrolments           SubjectEnrolment[]
  affiliate            Affiliate?
  referral             Referral?            @relation("ReferredUser")

  @@index([referredByCode])
}

model Subject {
  id         String             @id @default(cuid())
  name       String             @unique
  slug       String             @unique
  order      Int                @default(0)
  createdAt  DateTime           @default(now())
  enrolments SubjectEnrolment[]
}

model SubjectEnrolment {
  id                    String              @id @default(cuid())
  userId                String
  subjectId             String
  tier                  EnrolmentTier       @default(FREE)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @default(now()) @updatedAt
  stripeSubscriptionId  String?             @unique
  stripePriceId         String?
  subscriptionStatus    SubscriptionStatus?
  currentPeriodEnd      DateTime?
  cancelAtPeriodEnd     Boolean             @default(false)
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject               Subject             @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([userId, subjectId])
  @@index([userId])
  @@index([subjectId])
}

model ExtractionSession {
  id        String   @id @default(cuid())
  userId    String
  pdfName   String
  result    Json
  statuses  Json
  done      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model ExamSession {
  id             String   @id @default(cuid())
  userId         String
  mode           String
  totalQuestions  Int
  correctCount   Int
  incorrectCount Int
  score          Float
  elapsedSeconds Int?
  graded         Boolean  @default(true)
  completedAt    DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, completedAt])
}

model Attempt {
  id          String        @id @default(cuid())
  userId      String
  questionId  String
  status      AttemptStatus @default(ATTEMPTED)
  marksEarned Int?
  createdAt   DateTime      @default(now())
  question    Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId])
  @@index([questionId])
}

enum ExamType {
  EXAM_1
  EXAM_2
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Role {
  STUDENT
  TUTOR
  INFLUENCER
  ADMIN
  SUPER_ADMIN
}

enum AttemptStatus {
  ATTEMPTED
  CORRECT
  INCORRECT
  NEEDS_REVIEW
}

enum EnrolmentTier {
  FREE
  PAID
}

model QuestionSet {
  id          String            @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  items       QuestionSetItem[]
}

model QuestionSetItem {
  id            String              @id @default(cuid())
  questionSetId String
  topicId       String
  type          QuestionSetItemType
  order         Int                 @default(0)
  marks         Int
  content       String
  // MCQ-only fields (4 options A–D)
  optionA       String?
  optionB       String?
  optionC       String?
  optionD       String?
  correctOption String? // "A" | "B" | "C" | "D"
  // Solution
  solutionContent String?
  difficulty    Difficulty          @default(MEDIUM)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  questionSet   QuestionSet         @relation(fields: [questionSetId], references: [id], onDelete: Cascade)
  topic         Topic               @relation(fields: [topicId], references: [id])
  subtopics     Subtopic[]          @relation("QuestionSetItemToSubtopic")

  @@index([questionSetId])
  @@index([topicId])
}

enum QuestionSetItemType {
  MCQ
  SHORT_ANSWER
  EXTENDED_RESPONSE
}

enum SubscriptionStatus {
  active
  trialing
  past_due
  canceled
  unpaid
  incomplete
  incomplete_expired
  paused
}

// =====================================================
// Affiliate Program
// =====================================================

enum AffiliateType {
  STUDENT_REFERRAL    // Track A — students earn $5 platform credit
  TUTOR_AFFILIATE     // Track B — tutors earn $10 cash per referral
  INFLUENCER_AFFILIATE // Track C — influencers earn $10 + content fee
}

enum ReferralStatus {
  PENDING    // Signed up via referral, no paid subscription yet
  CONVERTED  // First paid subscription successful
  EXPIRED    // Did not convert within window
  REFUNDED   // Subscription refunded — reward clawed back
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Affiliate {
  id            String        @id @default(cuid())
  userId        String        @unique
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          AffiliateType
  referralCode  String        @unique
  abn           String?       // Required for TUTOR/INFLUENCER
  approved      Boolean       @default(false)
  active        Boolean       @default(true)
  creditBalance Int           @default(0)  // Cents — Track A platform credit
  notes         String?       // Admin notes
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  referrals    Referral[]
  payouts      Payout[]
  contracts    InfluencerContract[]

  @@index([type])
  @@index([approved])
}

model Referral {
  id              String         @id @default(cuid())
  affiliateId     String
  affiliate       Affiliate      @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  referredUserId  String         @unique
  referredUser    User           @relation("ReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)
  status          ReferralStatus @default(PENDING)
  rewardAmount    Int            @default(0)  // Cents — set on conversion (500 student / 1000 tutor+influencer)
  rewardPaid      Boolean        @default(false)
  createdAt       DateTime       @default(now())
  convertedAt     DateTime?

  @@index([affiliateId])
  @@index([status])
}

model Payout {
  id          String       @id @default(cuid())
  affiliateId String
  affiliate   Affiliate    @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  amount      Int          // Cents
  type        PayoutType   @default(COMMISSION)
  status      PayoutStatus @default(PENDING)
  method      String?      // e.g. "bank_transfer"
  reference   String?      // External payment reference
  notes       String?
  createdAt   DateTime     @default(now())
  processedAt DateTime?

  @@index([affiliateId])
  @@index([status])
}

enum PayoutType {
  COMMISSION   // Per-referral commission
  CONTENT_FEE  // Influencer upfront content payment
}

model InfluencerContract {
  id               String    @id @default(cuid())
  affiliateId      String
  affiliate        Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  platform         String    // YouTube, TikTok, Instagram, etc
  platformHandle   String    // @username or channel URL
  followerCount    Int?      // Optional, for admin reference
  contentFee       Int       // Upfront payment in cents
  feePaid          Boolean   @default(false)
  contentUrl       String?   // Link to published video
  contentDeadline  DateTime?
  contentVerified  Boolean   @default(false)
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([affiliateId])
}
