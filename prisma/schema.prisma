generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Syllabus Structure ───────────────────────────────────────────────────────

model Topic {
  id          String     @id @default(cuid())
  name        String     @unique   // e.g. "Calculus"
  slug        String     @unique   // e.g. "calculus"
  description String?
  order       Int        @default(0)
  subtopics   Subtopic[]
  questions   Question[]
  createdAt   DateTime   @default(now())
}

model Subtopic {
  id        String     @id @default(cuid())
  name      String                          // e.g. "Differentiation"
  slug      String                          // e.g. "differentiation"
  order     Int        @default(0)
  topicId   String
  topic     Topic      @relation(fields: [topicId], references: [id], onDelete: Cascade)
  questions Question[]

  @@unique([topicId, slug])
}

// ─── Exams ────────────────────────────────────────────────────────────────────

model Exam {
  id        String     @id @default(cuid())
  year      Int
  examType  ExamType                        // EXAM_1 or EXAM_2
  pdfUrl    String?                         // Supabase Storage URL
  answerUrl String?                         // Answer/solution PDF URL
  questions Question[]
  createdAt DateTime   @default(now())

  @@unique([year, examType])
}

enum ExamType {
  EXAM_1
  EXAM_2
}

// ─── Questions ────────────────────────────────────────────────────────────────

model Question {
  id           String     @id @default(cuid())
  examId       String
  exam         Exam       @relation(fields: [examId], references: [id], onDelete: Cascade)
  topicId      String
  topic        Topic      @relation(fields: [topicId], references: [id])
  subtopicId   String?
  subtopic     Subtopic?  @relation(fields: [subtopicId], references: [id])

  questionNumber Int                        // e.g. 3
  part           String?                   // e.g. "a", "b", "c"
  marks          Int
  content        String                    // Question text (may include LaTeX)
  imageUrl       String?                   // Optional image/diagram URL
  difficulty     Difficulty @default(MEDIUM)

  solution       Solution?
  attempts       Attempt[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

// ─── Solutions ────────────────────────────────────────────────────────────────

model Solution {
  id         String   @id @default(cuid())
  questionId String   @unique
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  content    String                        // Solution text / LaTeX
  imageUrl   String?                       // Optional worked solution image
  videoUrl   String?                       // Optional YouTube / video link
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Users & Progress ─────────────────────────────────────────────────────────

model User {
  id        String    @id                  // Matches Supabase Auth user UUID
  email     String    @unique
  name      String?
  role      Role      @default(STUDENT)
  attempts  Attempt[]
  createdAt DateTime  @default(now())
}

enum Role {
  STUDENT
  ADMIN
}

model Attempt {
  id         String        @id @default(cuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId String
  question   Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  status     AttemptStatus @default(ATTEMPTED)
  marksEarned Int?
  createdAt  DateTime      @default(now())

  @@unique([userId, questionId])
}

enum AttemptStatus {
  ATTEMPTED
  CORRECT
  INCORRECT
  NEEDS_REVIEW
}
