generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Topic {
  id          String     @id @default(cuid())
  name        String     @unique
  createdAt   DateTime   @default(now())
  description String?
  order       Int        @default(0)
  slug        String     @unique
  questions   Question[]
  subtopics   Subtopic[]
}

model Subtopic {
  id        String     @id @default(cuid())
  name      String
  slug      String
  order     Int        @default(0)
  topicId   String
  topic     Topic      @relation(fields: [topicId], references: [id], onDelete: Cascade)
  questions Question[] @relation("QuestionToSubtopic")

  @@unique([topicId, slug])
}

model Exam {
  id        String     @id @default(cuid())
  year      Int
  examType  ExamType
  createdAt DateTime   @default(now())
  answerUrl String?
  pdfUrl    String?
  questions Question[]

  @@unique([year, examType])
}

model Question {
  id             String     @id @default(cuid())
  examId         String
  marks          Int
  createdAt      DateTime   @default(now())
  content        String
  difficulty     Difficulty @default(MEDIUM)
  imageUrl       String?
  part           String?
  questionNumber Int
  topicId        String
  updatedAt      DateTime   @updatedAt
  attempts       Attempt[]
  exam           Exam       @relation(fields: [examId], references: [id], onDelete: Cascade)
  topic          Topic      @relation(fields: [topicId], references: [id])
  solution       Solution?
  subtopics      Subtopic[] @relation("QuestionToSubtopic")

  @@index([topicId, difficulty])
  @@index([examId, questionNumber])
  @@index([topicId, examId])
}

model Solution {
  id         String   @id @default(cuid())
  questionId String   @unique
  content    String
  imageUrl   String?
  videoUrl   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model User {
  id           String        @id
  email        String        @unique
  name         String?
  createdAt    DateTime      @default(now())
  role         Role          @default(STUDENT)
  attempts     Attempt[]
  examSessions ExamSession[]
}

model ExamSession {
  id             String   @id @default(cuid())
  userId         String
  mode           String
  totalQuestions  Int
  correctCount   Int
  incorrectCount Int
  score          Float
  elapsedSeconds Int?
  completedAt    DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, completedAt])
}

model Attempt {
  id          String        @id @default(cuid())
  userId      String
  questionId  String
  status      AttemptStatus @default(ATTEMPTED)
  marksEarned Int?
  createdAt   DateTime      @default(now())
  question    Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId])
  @@index([questionId])
}

enum ExamType {
  EXAM_1
  EXAM_2
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Role {
  STUDENT
  ADMIN
}

enum AttemptStatus {
  ATTEMPTED
  CORRECT
  INCORRECT
  NEEDS_REVIEW
}
